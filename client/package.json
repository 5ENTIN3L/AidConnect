{
  "name": "ngo-aid-frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "appwrite": "^23.0.0",
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "framer-motion": "^12.35.2",
    "lenis": "^1.3.18",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:ci": "react-scripts test --watch=false --coverage",
    "test:e2e": "playwright test",
    "test:e2e:auth": "playwright test -c playwright.auth.config.js",
    "build:test": "cross-env REACT_APP_APPWRITE_ENDPOINT=http://127.0.0.1:65535/v1 REACT_APP_APPWRITE_PROJECT_ID=test-project REACT_APP_APPWRITE_DATABASE_ID=aidconnect_db react-scripts build",
    "build:test:real": "react-scripts build",
    "serve:build": "serve -s build -l 3000",
    "start:test": "cross-env BROWSER=none REACT_APP_APPWRITE_ENDPOINT=http://127.0.0.1:65535/v1 REACT_APP_APPWRITE_PROJECT_ID=test-project REACT_APP_APPWRITE_DATABASE_ID=aidconnect_db react-scripts start",
    "start:test:real": "cross-env BROWSER=none react-scripts start",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "cross-env": "^7.0.3",
    "serve": "^14.2.4"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
